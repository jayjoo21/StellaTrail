cmake_minimum_required(VERSION 3.10)
project(StellaTrail)

set(CMAKE_CXX_STANDARD 17)
set(CMAKE_CXX_STANDARD_REQUIRED ON)

# Try to find SDL2 (prefer config mode from vcpkg, fall back to module mode)
find_package(SDL2 CONFIG QUIET)

if(NOT TARGET SDL2::SDL2 AND NOT TARGET SDL2::SDL2-static)
    # Fallback to FindSDL2 module (sets SDL2_INCLUDE_DIRS and SDL2_LIBRARIES)
    find_package(SDL2 REQUIRED)
endif()

# main.cpp를 실행 파일로 빌드
add_executable(StellaTrail main.cpp)

# SDL2 라이브러리 링크: use targets when available, otherwise use module variables
if(TARGET SDL2::SDL2 OR TARGET SDL2::SDL2-static)
    target_link_libraries(StellaTrail PRIVATE
        $<TARGET_NAME_IF_EXISTS:SDL2::SDL2main>
        $<IF:$<TARGET_EXISTS:SDL2::SDL2>,SDL2::SDL2,SDL2::SDL2-static>
    )
else()
    target_include_directories(StellaTrail PRIVATE ${SDL2_INCLUDE_DIRS})
    target_link_libraries(StellaTrail PRIVATE ${SDL2_LIBRARIES})
endif()
